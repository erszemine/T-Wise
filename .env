

# src_backend/.env

# MongoDB Kimlik Bilgileri (Compass'taki ile aynı olmalı)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=Sistem

# MongoDB URI (backend'i docker compasste çalıştıracaksanız):
MONGO_URI=mongodb://admin:Sistem@mongodb:27017/stock_management_db?authSource=admin

# Eğer backend'i Docker içinde çalıştıracaksanız (mongodb service adını kullanın):
# MONGO_URI=mongodb://admin:Sistem@mongodb:27017/stock_management_db?authSource=admin

JWT_SECRET_KEY="your_super_secret_jwt_key_here_for_fastapi_prod_only"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
